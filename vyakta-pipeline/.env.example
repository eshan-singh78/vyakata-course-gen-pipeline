# LLM Provider: anthropic or openai
LLM_PROVIDER=anthropic

# API Keys (only the one matching provider is required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model selection
MODEL_NAME=claude-sonnet-4-6

# Pipeline behavior
MAX_RETRIES=3
TIMEOUT_SECONDS=120
TEMPERATURE=0.2
OUTPUT_DIR=./output
